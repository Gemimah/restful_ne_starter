# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/ne_exam_db?schema=public"

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-before-exam
JWT_EXPIRES_IN=7d

# OTP
OTP_EXPIRES_MINUTES=10

# Email (Gmail example — use App Password, not your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="NE Exam App <your-email@gmail.com>"
